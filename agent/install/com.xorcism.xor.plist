<?xml version="1.0" encoding="UTF-8"?>
<!-- launchd : /Library/LaunchDaemons/com.xorcism.xor.plist  (enrôler une fois avant) -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.xorcism.xor</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/opt/xor/xor_agent.py</string>
    <string>--run</string>
    <string>--interval</string><string>300</string>
    <string>--conf</string><string>/opt/xor/xor_agent.conf</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
</dict>
</plist>
